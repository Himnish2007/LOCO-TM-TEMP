# ---- HIMNISH RAIP LOCO monitoring environment ----
PORT=8080

# Persistent state (users/sheds/locos/thresholds). On Railway attach a Volume
# and set DATA_DIR to its mount path so data survives redeploys.
DATA_DIR=./data

# Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_TTL=12h

# Key for the generic /api/v1/ingest route (readings[] batch format)
DATA_API_KEY=himnish_loco_key_2026

# Key for the EXISTING himnish_push.lua RUT200 script — matches its hardcoded
# K value exactly. The script is not modified; only its URL changes at cutover.
PUSH_API_KEY=himnish_rut200_key_2024

# Synthetic data generator (no hardware). Leave false in production.
DEMO_MODE=false
DEMO_SHEDS=2

# RUT200 IP pull poller interval in seconds (0 = disabled) — not used by the
# push-based lua script, kept for any future pull-mode devices.
POLL_INTERVAL=20

# Default thresholds (deg C) — Warning 120 / High 140 / Critical 160
CFG_WARN_TEMP=120
CFG_HIGH_TEMP=140
CFG_CRIT_TEMP=160
CFG_OFFLINE_SECONDS=300

# Optional PostgreSQL/TimescaleDB archive (durable history). Leave unset for
# in-memory + JSON only.
DATABASE_URL=

# Optional SMTP for email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional SMS provider: log (dry-run) | fast2sms | msg91 | generic
SMS_PROVIDER=log
SMS_API_KEY=
SMS_SENDER=HMNISH
